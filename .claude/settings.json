{
  "permissions": {
    "allow": [
      "Edit",
      "Read",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(echo *)"
    ],
    "deny": [
      "Read(~/.aws/**)",
      "Write(~/.bashrc)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-bash.sh",
            "statusMessage": "Running safety check",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
