{
  "model": "haiku",
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": ["Edit", "Read"]
  },
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": false
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-bash.sh",
            "statusMessage": "Bash hook",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
